<!-- File: src/main/resources/log4j2.xml -->
<?xml version="1.0" encoding="UTF-8"?>
<!--
    Cấu hình Log4j2 cho AMHS/SWIM Gateway Test Tool.
    Tuân thủ yêu cầu ghi log lưu lượng (Traffic Logging) theo EUR Doc 047.
    Các log sẽ được ghi ra console và file để phục vụ kiểm tra và giám sát.
-->
<Configuration status="WARN">
    <Appenders>
        <!-- Console Appender: Hiển thị log trên màn hình console trong quá trình chạy test -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>

        <!-- File Appender: Ghi log lưu lượng vào file traffic.log -->
        <!-- Yêu cầu từ EUR Doc 047: Lưu trữ log ít nhất 30 ngày -->
        <RollingFile name="TrafficFile" fileName="logs/traffic.log"
                     filePattern="logs/traffic-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout>
                <Pattern>%d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %logger{36} - %msg%n</Pattern>
            </PatternLayout>
            <Policies>
                <!-- Xoay vòng file log mỗi ngày -->
                <TimeBasedTriggeringPolicy/>
                <!-- Xoay vòng khi file đạt 10MB -->
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

        <!-- File Appender: Ghi log lỗi và sự kiện hệ thống -->
        <RollingFile name="ErrorFile" fileName="logs/error.log"
                     filePattern="logs/error-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout>
                <Pattern>%d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %logger{36} - %msg%n</Pattern>
            </PatternLayout>
            <Policies>
                <TimeBasedTriggeringPolicy/>
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- Logger chính cho công cụ kiểm thử -->
        <Logger name="com.amhs.swim.test" level="info" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="TrafficFile"/>
        </Logger>

        <!-- Logger cho các lỗi nghiêm trọng -->
        <Logger name="com.amhs.swim.test.error" level="error" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ErrorFile"/>
        </Logger>

        <!-- Root Logger -->
        <Root level="warn">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>