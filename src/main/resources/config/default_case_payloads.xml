<?xml version="1.0" encoding="UTF-8"?>
<!--
  ICAO EUR Doc 047 AMHS/SWIM Gateway Test Tool
  Standardized Default Case Payloads

  These values represent the ICAO-mandated configuration standards per EUR Doc 047.
  Users may override them per-session via the config screen — but this file is the
  authoritative reference (the "testbook intent"). Do NOT edit this file.
  Runtime overrides are stored in config/case_payloads.json.

  Pipe-separated payload fields are parsed left-to-right as config screen fields.
-->
<defaults>

  <!-- CTSW101: Convert AMQP unaware message -->
  <case id="CTSW101">
    <msg idx="1"><![CDATA[CTSW101 Text Payload]]></msg>
    <msg idx="2"><![CDATA[src/main/resources/sample.pdf]]></msg>
  </case>

  <!-- CTSW102: Reject AMQP messages missing required information
       Fields: payload (text), or file path (binary), plus per-message extras.
       Msg 11: recip_11 = the >8-char recipient that must be rejected (EUR Doc 047 §4.5.1.4) -->
  <case id="CTSW102">
    <msg idx="1"><![CDATA[CTSW102 Erroneous Message 1]]></msg>
    <msg idx="2"><![CDATA[CTSW102 Erroneous Message 2]]></msg>
    <msg idx="3"><![CDATA[CTSW102 Erroneous Message 3]]></msg>
    <msg idx="4"><![CDATA[]]></msg>
    <msg idx="5"><![CDATA[CTSW102 Erroneous Message 5]]></msg>
    <msg idx="6"><![CDATA[CTSW102 Erroneous Message 6]]></msg>
    <msg idx="7"><![CDATA[src/main/resources/sample.pdf]]></msg>
    <msg idx="8"><![CDATA[src/main/resources/sample.pdf]]></msg>
    <msg idx="9"><![CDATA[src/main/resources/sample.pdf]]></msg>
    <msg idx="10"><![CDATA[]]></msg>
    <!-- msg 11: pipe-separated => binPayload_11 | recip_11
         recip_11 must be >8 chars to trigger REJECT per EUR Doc 047 §4.5.1.4 -->
    <msg idx="11"><![CDATA[src/main/resources/sample.pdf|LONGADDRESSXXXXX]]></msg>
    <msg idx="12"><![CDATA[src/main/resources/sample.pdf]]></msg>
  </case>

  <!-- CTSW103: ATSMHS Service Level conversion -->
  <case id="CTSW103">
    <msg idx="1"><![CDATA[CTSW103 Basic Text Payload]]></msg>
    <msg idx="2"><![CDATA[src/main/resources/sample.pdf]]></msg>
    <msg idx="3"><![CDATA[CTSW103 Extended Text Payload]]></msg>
    <msg idx="4"><![CDATA[src/main/resources/sample.pdf]]></msg>
    <msg idx="5"><![CDATA[CTSW103 ContentBased Text Payload]]></msg>
    <msg idx="6"><![CDATA[CTSW103 RecipBased AllExt Payload]]></msg>
    <msg idx="7"><![CDATA[CTSW103 RecipBased Mixed Payload]]></msg>
  </case>

  <!-- CTSW104: Priority mapping - values shown are payload defaults only;
       actual priority is set per-message in the case logic -->
  <case id="CTSW104">
    <msg idx="1"><![CDATA[CTSW104 Priority 0 Text]]></msg>
    <msg idx="2"><![CDATA[CTSW104 Priority 1 Text]]></msg>
    <msg idx="3"><![CDATA[CTSW104 Priority 2 Text]]></msg>
    <msg idx="4"><![CDATA[CTSW104 Priority 3 Text]]></msg>
    <msg idx="5"><![CDATA[CTSW104 Priority 4 Text]]></msg>
    <msg idx="6"><![CDATA[CTSW104 Priority 5 Text]]></msg>
    <msg idx="7"><![CDATA[CTSW104 Priority 6 Text]]></msg>
    <msg idx="8"><![CDATA[CTSW104 Priority 7 Text]]></msg>
    <msg idx="9"><![CDATA[CTSW104 Priority 8 Text]]></msg>
    <msg idx="10"><![CDATA[CTSW104 Priority 9 Text]]></msg>
    <msg idx="11"><![CDATA[CTSW104 Pri4+ATS_SS]]></msg>
    <msg idx="12"><![CDATA[CTSW104 Pri4+ATS_DD]]></msg>
    <msg idx="13"><![CDATA[CTSW104 Pri4+ATS_FF]]></msg>
    <msg idx="14"><![CDATA[CTSW104 Pri4+ATS_GG]]></msg>
    <msg idx="15"><![CDATA[CTSW104 Pri4+ATS_KK]]></msg>
    <msg idx="16"><![CDATA[CTSW104 Pri1+ATS_SS]]></msg>
    <msg idx="17"><![CDATA[CTSW104 Pri1+ATS_DD]]></msg>
    <msg idx="18"><![CDATA[CTSW104 Pri1+ATS_FF]]></msg>
    <msg idx="19"><![CDATA[CTSW104 Pri1+ATS_GG]]></msg>
    <msg idx="20"><![CDATA[CTSW104 Pri9+ATS_KK]]></msg>
  </case>

  <!-- CTSW105: Filing time conversion -->
  <case id="CTSW105">
    <msg idx="1"><![CDATA[CTSW105 Default Filing Time Text]]></msg>
    <msg idx="2"><![CDATA[CTSW105 Explicit Filing Time 250102]]></msg>
  </case>

  <!-- CTSW106: Optional Heading Information - pipe-separated: OHI | BODY -->
  <case id="CTSW106">
    <msg idx="1"><![CDATA[OHI-SHORT|OHI Content]]></msg>
    <msg idx="2"><![CDATA[AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA|OHI Content]]></msg>
    <msg idx="3"><![CDATA[AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA|OHI Content]]></msg>
    <msg idx="4"><![CDATA[OHI-HI-SHORT|OHI Content]]></msg>
    <msg idx="5"><![CDATA[BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB|OHI Content]]></msg>
    <msg idx="6"><![CDATA[BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB|OHI Content]]></msg>
  </case>

  <!-- CTSW107: Subject field mapping - pipe-separated:
       msg1/2: AMQP_SUBJECT | BODY
       msg3:   AMHS_SUBJECT | BODY
       msg4:   AMQP_SUBJECT | AMHS_SUBJECT | BODY -->
  <case id="CTSW107">
    <msg idx="1"><![CDATA[SSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSS|Msg1 Payload]]></msg>
    <msg idx="2"><![CDATA[Normal Subject|Msg2 Payload]]></msg>
    <msg idx="3"><![CDATA[AMHS App Prop Subject|Msg3 Payload]]></msg>
    <msg idx="4"><![CDATA[AMQP Subject Props|AMHS App Prop|Msg4 Payload]]></msg>
  </case>

  <!-- CTSW108: Known originator - pipe-separated: AMHS_ORIGINATOR | BODY -->
  <case id="CTSW108">
    <msg idx="1"><![CDATA[VVTSYMYX|Known Originator Body]]></msg>
  </case>

  <!-- CTSW109: Unknown originator - pipe-separated: AMHS_ORIGINATOR | BODY -->
  <case id="CTSW109">
    <msg idx="1"><![CDATA[UNKNOWN1|Unknown Originator Body]]></msg>
  </case>

  <!-- CTSW110: Content-type combinations -->
  <case id="CTSW110">
    <msg idx="1"><![CDATA[]]></msg>
    <msg idx="2"><![CDATA[src/main/resources/sample.pdf]]></msg>
    <msg idx="3"><![CDATA[src/main/resources/sample.pdf]]></msg>
    <msg idx="4"><![CDATA[CTSW110 Text Accept Payload]]></msg>
    <msg idx="5"><![CDATA[CTSW110 UTF-16 Payload]]></msg>
    <msg idx="6"><![CDATA[CTSW110 Both Body Parts Payload]]></msg>
  </case>

  <!-- CTSW111: Message size limit -->
  <case id="CTSW111">
    <msg idx="1"><![CDATA[CTSW111 Small Text Within Limit]]></msg>
    <msg idx="2"><![CDATA[src/main/resources/small_payload.bin]]></msg>
    <msg idx="3"><![CDATA[OVER_SIZE_TEXT]]></msg>
    <msg idx="4"><![CDATA[src/main/resources/large_payload.bin]]></msg>
  </case>

  <!-- CTSW112: Recipient quantity limit -->
  <case id="CTSW112">
    <msg idx="1"><![CDATA[src/main/resources/address_512.txt]]></msg>
    <msg idx="2"><![CDATA[src/main/resources/address_513.txt]]></msg>
  </case>

  <!-- CTSW113: Receipt / Non-receipt notification
       amhs_notification_request=rn,nrn is mandated by EUR Doc 047 §4.4.7.3
       It is the standard — editable per-session via config screen. -->
  <case id="CTSW113">
    <!-- pipe-separated: payload | amhs_notification_request -->
    <msg idx="1"><![CDATA[CTSW113 NRN Request Payload|rn,nrn]]></msg>
    <msg idx="2"><![CDATA[CTSW113 RN Request Payload|rn,nrn]]></msg>
  </case>

  <!-- CTSW114: Non-delivery report -->
  <case id="CTSW114">
    <msg idx="1"><![CDATA[CTSW114 Trigger NDR Payload]]></msg>
  </case>

  <!-- CTSW115: Body-part type and content encoding
       Mandated by EUR Doc 047 §4.5.2.4-4.5.2.5, Table 10-11
       pipe-separated: payload | amhs_bodypart_type | amhs_content_encoding -->
  <case id="CTSW115">
    <msg idx="1"><![CDATA[Lorem ipsum|ia5-text|IA5]]></msg>
    <msg idx="2"><![CDATA[Lorem ipsum i5bpt|ia5_text_body_part|IA5]]></msg>
    <msg idx="3"><![CDATA[Lorem ipsum 646|general-text-body-part|ISO-646]]></msg>
    <msg idx="4"><![CDATA[Lorem ipsum 8859|general-text-body-part|ISO-8859-1]]></msg>
  </case>

  <!-- CTSW116: FTBP attributes and GZIP
       pipe-separated: file_path | amhs_ftbp_last_mod
       amhs_ftbp_file_name and amhs_ftbp_object_size are derived from file at runtime. -->
  <case id="CTSW116">
    <msg idx="1"><![CDATA[src/main/resources/sample.pdf|240101120000Z]]></msg>
    <msg idx="2"><![CDATA[src/main/resources/sample.pdf|240101120000Z]]></msg>
  </case>

</defaults>
